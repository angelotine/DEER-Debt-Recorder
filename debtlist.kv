#:kivy 2.3.0

<SelectableButton>:
    address_text: ""
    debt_text: ""
    canvas.before:
        Color:
            rgba: (1, 1, 1, 1) if self.state == 'normal' else (0.92, 0.92, 0.92, 1)
        RoundedRectangle:
            pos: (self.x + dp(10), self.y + dp(5))
            size: (self.width - dp(20), self.height - dp(10))
            radius: [dp(12),]
    background_normal: ''
    background_color: (0, 0, 0, 0)
    
    BoxLayout:
        orientation: 'horizontal'
        padding: [dp(20), dp(10)]
        spacing: dp(10)
        pos: root.pos
        size: root.size

        BoxLayout:
            orientation: 'vertical'
            Label:
                text: root.text
                markup: True
                color: (0.1, 0.1, 0.1, 1)
                halign: 'left'
                text_size: self.width, None
                font_size: '16sp'
            Label:
                text: root.address_text
                color: (0.4, 0.4, 0.4, 1)
                halign: 'left'
                text_size: self.width, None
                font_size: '13sp'
            Label:
                text: root.debt_text
                markup: True
                color: (0.18, 0.49, 0.2, 1) if root.debt_text != "SETTLED" else (0.4, 0.4, 0.4, 1)
                halign: 'left'
                text_size: self.width, None
                font_size: '15sp'
                bold: True

        BoxLayout:
            size_hint_x: None
            width: dp(150) if root.debt_text == "SETTLED" else dp(80)
            spacing: dp(8)
            pos_hint: {'center_y': 0.5}

            Button:
                text: 'DEL'
                size_hint: (1, None)
                height: dp(45)
                background_normal: ''
                background_color: (0.8, 0.2, 0.2, 1) if self.state == 'normal' else (0.5, 0.1, 0.1, 1)
                bold: True
                opacity: 1 if root.debt_text == "SETTLED" else 0
                disabled: True if root.debt_text != "SETTLED" else False
                on_release: root.confirm_delete()

            Button:
                text: 'UNPAID' if root.debt_text == "SETTLED" else 'PAID'
                size_hint: (1, None)
                height: dp(45)
                background_normal: ''
                background_color: ((0.7, 0.4, 0.1, 1) if root.debt_text == "SETTLED" else (0.18, 0.49, 0.2, 1)) if self.state == 'normal' else (0.1, 0.2, 0.1, 1)
                bold: True
                on_release: 
                    if root.debt_text == "SETTLED": root.mark_as_unpaid()
                    else: root.mark_as_paid()

<DebtListScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.95, 0.95, 0.95, 1)
            Rectangle:
                pos: self.pos
                size: self.size
        BoxLayout:
            size_hint_y: None
            height: '65dp'
            padding: [dp(10), 0]
            canvas.before:
                Color:
                    rgba: (0.18, 0.49, 0.2, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: '<'
                size_hint_x: None
                width: '50dp'
                background_normal: ''
                background_color: (0, 0, 0, 0)
                font_size: '22sp'
                on_release: 
                    root.manager.transition.direction = 'right'
                    root.manager.current = 'home'
            Label:
                text: 'Active Debts'
                bold: True
                font_size: '20sp'
        BoxLayout:
            size_hint_y: None
            height: '65dp'
            padding: dp(10)
            TextInput:
                id: search_input
                hint_text: 'Search customer name...'
                multiline: False
                on_text: root.update_list(self.text)
                padding: [dp(10), dp(10)]
        RecycleView:
            id: rv
            viewclass: 'SelectableButton'
            RecycleBoxLayout:
                default_size: None, dp(115)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(10)
                padding: dp(12)