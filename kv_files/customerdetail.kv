#:kivy 2.3.0

<CustomerDetailScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.95, 0.95, 0.95, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: '65dp'
            padding: [dp(10), 0]
            canvas.before:
                Color:
                    rgba: (0.18, 0.49, 0.2, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: '<'
                size_hint_x: None
                width: '50dp'
                background_normal: ''
                background_color: (0, 0, 0, 0)
                font_size: '22sp'
                on_release: root.back()
            Label:
                text: 'Details'
                bold: True
                font_size: '20sp'
            Button:
                id: edit_toggle_btn
                text: 'EDIT'
                size_hint_x: None
                width: '80dp'
                background_normal: ''
                background_color: (0, 0, 0, 0)
                on_release: root.toggle_edit_mode()

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: dp(15)
                spacing: dp(15)

                TextInput:
                    id: name_input
                    hint_text: 'Name of the person who has a debt/order'
                    size_hint_y: None
                    height: dp(50)
                    multiline: False
                    padding: [dp(12), dp(12)]
                
                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(10)
                    TextInput:
                        id: phone_input
                        hint_text: 'Enter Phone number (Optional)'
                        multiline: False
                        input_filter: 'int'
                        padding: [dp(12), dp(12)]
                    Button:
                        text: 'CALL'
                        size_hint_x: None
                        width: dp(80)
                        background_normal: ''
                        background_color: (0.2, 0.6, 0.2, 1) if self.state == 'normal' else (0.1, 0.4, 0.1, 1)
                        bold: True
                        on_release: root.call_customer()
                
                TextInput:
                    id: address_input
                    hint_text: 'Address'
                    size_hint_y: None
                    height: dp(50)
                    multiline: False
                    padding: [dp(12), dp(12)]

                BoxLayout:
                    id: edit_actions
                    size_hint_y: None
                    height: 0
                    opacity: 0
                    spacing: dp(10)
                    Button:
                        text: 'DELETE'
                        background_normal: ''
                        background_color: (0.8, 0.2, 0.2, 1)
                        on_release: root.delete_customer()
                    Button:
                        text: 'SAVE'
                        background_normal: ''
                        background_color: (0.18, 0.49, 0.2, 1)
                        on_release: root.update_customer_info()

                BoxLayout:
                    id: new_order_section
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(230)
                    spacing: dp(10)
                    canvas.before:
                        Color:
                            rgba: (0.9, 0.9, 0.9, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(10),]
                    padding: dp(15)
                    Label:
                        text: 'ADD NEW DEBT / ORDER'
                        color: (0.2, 0.2, 0.2, 1)
                        bold: True
                        size_hint_y: None
                        height: dp(30)
                    TextInput:
                        id: order_desc
                        hint_text: 'Description'
                        size_hint_y: None
                        height: dp(45)
                    TextInput:
                        id: order_total
                        hint_text: 'Amount (₱)'
                        input_filter: 'float'
                        size_hint_y: None
                        height: dp(45)
                    Button:
                        text: 'CONFIRM DEBT / ORDER'
                        size_hint_y: None
                        height: dp(50)
                        background_normal: ''
                        background_color: (0.18, 0.49, 0.2, 1) if self.state == 'normal' else (0.1, 0.3, 0.1, 1)
                        on_release: root.add_order()

                Label:
                    id: history_label
                    markup: True
                    color: (0.2, 0.2, 0.2, 1)
                    size_hint_y: None
                    height: self.texture_size[1]
                    halign: 'left'
                    valign: 'top'
                    text_size: self.width, None