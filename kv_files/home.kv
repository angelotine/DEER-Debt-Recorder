#:kivy 2.3.0

<HomeScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(20)
        canvas.before:
            Color:
                rgba: (0.95, 0.95, 0.95, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: 0.5 
            Image:
                source: 'assets/logo.png'
                allow_stretch: True
                keep_ratio: True

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.5
            spacing: dp(12)
            padding: [dp(20), 0]

            Button:
                text: 'ADD NEW CUSTOMER'
                size_hint_y: None
                height: '60dp'
                background_normal: ''
                background_color: (0.18, 0.49, 0.2, 1)
                font_size: '18sp'
                bold: True
                on_release: root.add_new_debt()

            Button:
                text: 'VIEW ACTIVE DEBTS'
                size_hint_y: None
                height: '60dp'
                background_normal: ''
                background_color: (0.2, 0.2, 0.2, 1)
                font_size: '18sp'
                bold: True
                on_release: root.show_debts()

            Button:
                text: 'HISTORY'
                size_hint_y: None
                height: '60dp'
                background_normal: ''
                background_color: (0.4, 0.4, 0.4, 1)
                font_size: '18sp'
                bold: True
                on_release: root.manager.current = 'paidhistory'